# Local runtime profile for docker compose and Spring Boot.

MYSQL_DATABASE=bank_ai_assistant
MYSQL_USERNAME=root
MYSQL_PASSWORD=root123456
MYSQL_URL=jdbc:mysql://localhost:3306/bank_ai_assistant?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=replace-me
ALIYUN_OSS_ACCESS_KEY_SECRET=replace-me
ALIYUN_OSS_BUCKET=bank-ai-assistant
ALIYUN_OSS_PUBLIC_URL_PREFIX=

QWEN_API_KEY=replace-me
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v2

FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=0
